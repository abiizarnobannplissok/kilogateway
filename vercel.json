{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/dashboard.js",
      "dest": "public/dashboard.js"
    },
    {
      "src": "/index.html",
      "dest": "public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "public": true
}